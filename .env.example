# Alchemy connection (CPU-side, shadow desktop)
ALCHEMY_HOST=http://localhost:8000
ALCHEMY_TOKEN=

# GPU Models (via Ollama)
OLLAMA_HOST=http://localhost:11434
GPU_MODEL=qwen3:14b

# Voice
VOICE_ENABLED=true
WAKE_WORD=hey_neo
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
PIPER_MODEL=en_US-lessac-medium

# TTS Engine (piper = CPU fallback, fish = Fish Speech 1.5 GPU)
TTS_ENGINE=piper

# Fish Speech (only used when TTS_ENGINE=fish)
FISH_SPEECH_PORT=8080
FISH_SPEECH_CHECKPOINT=checkpoints/openaudio-s1-mini
FISH_SPEECH_HOST=127.0.0.1
FISH_SPEECH_SAMPLE_RATE=44100
FISH_SPEECH_REFERENCE_ID=
FISH_SPEECH_PYTHON_EXE=
FISH_SPEECH_DIR=

# GPU Mode (single = VRAM swapping, dual = all models resident)
GPU_MODE=single

# AlchemyVoice Server
HOST=127.0.0.1
PORT=8100
LOG_LEVEL=INFO
